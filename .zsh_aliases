#!/bin/zsh

# simple navigation
alias ~="cd ~;clear"
alias ..="cd .."
alias ...="cd ../.."
alias reload="source $HOME/.zshrc;clear"

# replacing ls with eza
# https://github.com/eza-community/eza
alias ls="eza -l --icons=always --hyperlink"
alias la="ls -a"
alias ld="ls --only-dirs"
alias lad="ls -a --only-dirs"


# Find and cd into a directory within ~/code using fzf
repo() {
  local dir=$(find ~/code -mindepth 1 -maxdepth 3 -type d | fzf --query="$1")
  [[ -n "$dir" ]] && cd "$dir"
}

gclone() {
  # 1. Strip the protocol (e.g., "https://") from the front of the URL
  local repo_path=${1#*//}
  local target_dir="$HOME/code/${repo_path%.git}"

  if [[ ! -d "$target_dir" ]]; then
    # Create parent directories, then clone.
    mkdir -p "${target_dir:h}" && git clone "$1" "$target_dir"
  fi

  # This command runs every time, taking you to the repo directory.
  cd "$target_dir"
}