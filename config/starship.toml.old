# Don't print a new line at the start of the prompt
add_newline = false

# Pure

format = """
$username\
$hostname\
$directory\
$git_branch\
$git_state\
$git_status\
$cmd_duration\
$line_break\
$python\
$character"""

continuation_prompt = """[.](bright-black) """

right_format="""$time"""

# Nerd Font Symbols

[aws]
symbol = "¯î¢  "

[buf]
symbol = "´ÆØ "

[c]
symbol = "¯İŞ "

[character]
success_symbol = "[ÔØ»](purple)"
error_symbol = "[ÔØ»](red)"
vimcmd_symbol = "[ÔØ«](green)"

[cmd_duration]
format = "[$duration]($style) "
style = "yellow"

[conda]
symbol = "´äî "

[crystal]
symbol = "¯İ» "

[dart]
symbol = "¯Şİ "

[directory]
style = "blue"
read_only = " ¾░î¥"

