#!/bin/zsh

# check all git repos in ~/code for uncommitted or unpushed changes
gstatus() {
  find ~/code -type d -name ".git" 2>/dev/null | while read gitdir; do
    repo_dir="${gitdir%.git}"
    cd "$repo_dir"

    # check for uncommitted changes
    if [[ -n $(git status --porcelain) ]]; then
      echo "📝 ${repo_dir#$HOME/code/} - dirty"
      continue
    fi

    # check for unpushed commits
    local branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    if [[ -n "$branch" ]]; then
      local unpushed=$(git log origin/$branch..HEAD 2>/dev/null | wc -l)
      if [[ $unpushed -gt 0 ]]; then
        echo "⬆️  ${repo_dir#$HOME/code/} - unpushed ($unpushed)"
      fi
    fi
  done
}

# clone git repo to organized structure
clone() {
  # strip protocol and www. from url
  local repo_path=${1#*//}
  repo_path=${repo_path#www.}
  local target_dir="$HOME/code/${repo_path%.git}"

  if [[ ! -d "$target_dir" ]]; then
    # create parent dirs, then clone
    mkdir -p "${target_dir:h}" && git clone "$1" "$target_dir"
  fi

  # always cd to the repo directory
  cd "$target_dir"
}

# find and cd into repo using fzf
repo() {
  local dir=$(find ~/code -mindepth 1 -maxdepth 3 -type d | fzf --query="$1")
  [[ -n "$dir" ]] && cd "$dir"
}